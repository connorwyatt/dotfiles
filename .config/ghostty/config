theme = dark:sakura-night,light:sakura-day

# background-opacity = 0.9
# background-blur = 100
# background-opacity-cells = true

mouse-hide-while-typing = true

cursor-click-to-move = false

# window-padding-x = 8
# window-padding-y = 8
window-padding-color = extend
# window-padding-color = extend-always
window-padding-balance = true

# macos-titlebar-style = hidden
# window-decoration = none

copy-on-select = false

# font-family = "IBM Plex Mono"
# font-style = Regular
# font-style-italic = Italic
# font-style-bold = Bold
# font-style-bold-italic = Bold Italic

# font-family = "Iosevka"
# font-style = Extended
# font-style-italic = Extended Oblique
# font-style-bold = Heavy Extended
# font-style-bold-italic = Heavy Extended Oblique

font-family = "Input Mono Condensed"
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = BoldIta

font-feature = -calt
font-feature = -liga
font-feature = -dlig

font-size = 14

adjust-cell-height = 20%

adjust-cursor-thickness = 4
adjust-cursor-height = 20%

keybind = global:cmd+ctrl+alt+space=toggle_quick_terminal
quick-terminal-position = right
quick-terminal-size = 35%, 100%
quit-after-last-window-closed = false
quick-terminal-autohide = false
