#!/bin/zsh

source ~/.config/zsh/sources/tmux.zsh

printf "\033]2;tmux-sessionizer\a"

base_directory="$HOME/Code"
script_dir="${0:a:h}"

config_paths=(
    ${(f)"$(jq -r '.[]' "$script_dir/resources/tmux-sessionizer-configurations.json")"}
    ${(f)"$(jq -r '.[]' "$script_dir/resources-local/tmux-sessionizer-configurations.json")"}
    ${(f)"$(fd '^.git$' $base_directory --hidden --exec bash -c 'cd {//}; git worktree list --porcelain' bash | \
        grep '^worktree ' | \
        grep -v '/.bare$' | \
        sd '^worktree ' '' | \
        sd "$HOME" '~')"}
)

config_paths=(${(ou)config_paths})

colorize_path() {
    local p=$1
    if [[ $p == */* ]]; then
        printf '\033[2m%s/\033[0m%s' "${p:h}" "${p:t}"
    else
        printf '%s' "$p"
    fi
}

selected=$(
    for p in $config_paths; do
        printf '%s\t%s\n' "$p" "$(colorize_path $p)"
    done | \
    fzf --exit-0 --scheme=path --delimiter=$'\t' --with-nth=2 --accept-nth=1 \
        --preview 'zsh -fc "bat --color=always --style=plain \${~argv[1]}/README.md 2>/dev/null" -- {1}')

if [[ -z $selected ]]; then
    exit 0
fi

tmux-create-or-attach $selected
