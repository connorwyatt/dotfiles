#!/bin/zsh

source ~/.config/zsh/sources/tmux.zsh

printf "\033]2;tmux-sessionizer\a"

base_directory="$HOME/Code"

selected=$(
    fd '^.git$' $HOME/Code --hidden --exec bash -c 'cd {//}; git worktree list --porcelain' bash | \
        grep '^worktree ' | \
        grep -v '/.bare$' | \
        sd '^worktree ' '' | \
        sd "$base_directory/" '' | \
        sort | \
        uniq | \
    fzf --exit-0 --preview "bat $base_directory/{}/README.md 2> /dev/null")

if [[ -z $selected ]]; then
    exit 0
fi

tmux-create-or-attach $base_directory/$selected $selected
